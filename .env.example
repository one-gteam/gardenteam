# Copia questo file in .env.local (mai committato) e compila con i valori
# del tuo progetto Supabase: Project Settings → API.

# Project URL (es. https://xxxxxxxx.supabase.co)
SUPABASE_URL=

# service_role key — ha accesso completo, la usa SOLO il server (mai esporla
# al browser, mai un prefisso NEXT_PUBLIC_).
SUPABASE_SERVICE_ROLE_KEY=

# Chiave API Claude per "Associa con AI" nella Macroarea ZOO — impostabile anche
# dall'interfaccia (Impostazioni → amministratore di sistema); questa variabile
# è solo un fallback opzionale se preferisci configurarla da ambiente.
# ANTHROPIC_API_KEY=
